# =========================================================
# Sensei Modern — environment template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real credentials.
# =========================================================

# ---- App ----
NODE_ENV=development
APP_URL=http://localhost:3000
APP_DEFAULT_LOCALE=es

# ---- Auth.js (NextAuth v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-long-random-string
AUTH_TRUST_HOST=true

# ---- PostgreSQL ----
# Matches docker-compose.yml defaults
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sensei
POSTGRES_PASSWORD=sensei
POSTGRES_DB=sensei
DATABASE_URL=postgresql://sensei:sensei@localhost:5432/sensei

# ---- Mail (Mailhog in dev) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Sensei Modern <no-reply@sensei.local>"

# ---- File storage ----
# dev: local | prod: s3
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./.uploads
# Only required when STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- Existing app discovery (Phase 2 only) ----
# Used by scripts/discover.ts to log in to the legacy app
# read-only and capture feature inventory. Never logged.
SENSEI_APP_URL=https://sensei.gojukan.app/
SENSEI_APP_USER=replace-me
SENSEI_APP_PASSWORD=replace-me

# ---- Logging ----
LOG_LEVEL=info
